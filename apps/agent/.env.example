SOURCE=mt5

# URL do endpoint de ingest (Vercel ou local)
INGEST_URL=https://pulse-app-navy-tau.vercel.app/api/ingest

# Token específico da conta MT5 (gere em /settings/accounts no Pulse)
INGEST_TOKEN=

# Caminho do terminal64.exe desta conta — obrigatório quando há mais de uma
# instalação MT5 no mesmo Windows (ex: XP MT5 + Hantec MT5).
MT5_PATH=C:\Program Files\XP MT5\terminal64.exe
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

SYMBOLS=WIN@N,WDO@N
TIMEFRAMES=M5,M15
